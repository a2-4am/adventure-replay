kAboutKeys
         !byte 0

kAboutKeyHandlers
         !word AboutEventDefault

DrawGlobalHelp
         ldx   #(kGameCount+1)
         bne   +                     ; always branches
DrawAbout
         ldx   GameID
+        jsr   LoadGametext
         lda   #$00
         sta   startLine
         lda   #$18
         sta   lineCount
         +LDADDR GAMETEXT
         jsr   DrawTextOffscreen
         jmp   MixedFizzle

AboutEventDefault
         jmp   GoBack
