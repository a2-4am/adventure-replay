kAboutKeys
         !byte 0

kAboutKeyHandlers
         !word AboutEventDefault

DrawAbout
         ldx   GameID
         +HIDE_NEXT_2_BYTES
DrawGlobalHelp
         ldx   #(kGameCount+1)
         jsr   LoadGametext
         lda   #$00
         sta   startLine
         lda   #$18
         sta   lineCount
         +LDADDR GAMETEXT
         jsr   DrawTextOffscreen
         jmp   MixedFizzle

AboutEventDefault
         jmp   GoBack
